# Database URL
# For SQLite (demo):
DATABASE_URL=sqlite:///resolvehq.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://username:password@localhost:5432/resolvehq

# JWT secret key (change this to a random string in production!)
JWT_SECRET_KEY=your-secret-key-change-in-production

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=True

# API host and port
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
